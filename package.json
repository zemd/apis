{
  "name": "apis",
  "private": true,
  "scripts": {
    "prebuild": "turbo telemetry disable",
    "build": "turbo build",
    "dev": "turbo dev",
    "generate": "turbo generate-api",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "release": "pnpm run build && changeset publish",
    "changeset": "changeset",
    "test": "turbo test",
    "test-http-client": "turbo test --filter @zemd/http-client",
    "prepare": "husky",
    "lint-publint": "pnpm --filter \"./packages/*\" --filter \"./apis/*\" --no-bail run lint-publint"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@zemd/eslint-ts": "3.0.3",
    "@zemd/tsconfig": "catalog:",
    "eslint": "10.3.0",
    "husky": "9.1.7",
    "prettier": "3.8.3",
    "publint": "0.3.20",
    "turbo": "2.9.12"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
}
